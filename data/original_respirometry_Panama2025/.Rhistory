raw_tree <- midpoint.root(raw_tree)
thetips <- raw_tree$tip.label
numtips <- length(thetips)
if(numtips<45){numtips <- 45}
cexval <- 233*numtips^-1.5
cexval <- round(cexval, 2)
if(cexval<0.05){cexval <- 0.05}
plot(raw_tree, cex=cexval, edge.width=0.1, type='phylogram' , show.tip.label=TRUE)
title('Tree File: Arr');
thetips <- raw_tree$tip.label
qlabels <- grep('QUERY',thetips)
tiplabels(tip=qlabels, pch=21, cex=cexval)
l1labels <- grep('LANDMARK1',thetips)
tiplabels(tip=l1labels, pch=15, cex=cexval, col='red')
