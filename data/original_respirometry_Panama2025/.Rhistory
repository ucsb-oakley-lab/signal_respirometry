# Function to print tip labels matching a specific pattern
print_similar_tip_labels <- function(tree, pattern) {
matching_labels <- grep(pattern, tree$tip.label, value = TRUE)
print(matching_labels)
}
# Search for similar tip labels for each MRCA pair
# For "XLR_Gloeobacter" and "Xlr__Leptolyngbya__UniRef90_A0A6H2NHV9"
