import math
from pathlib import Path

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from matplotlib.offsetbox import OffsetImage, AnnotationBbox
from matplotlib.patches import Rectangle

# =========================================================
# 1) INPUT DATA
# =========================================================

# Literature compilation
# Columns:
#   sp_no   = species number used in original figure/table
#   group   = major taxonomic group for icon choice
#   signal  = signaling metabolic rate (ml O2 g^-1 h^-1)
#   rest    = resting metabolic rate (ml O2 g^-1 h^-1)
lit = pd.DataFrame([
    (1,   "spider", 4.580, 0.220),
    (2,   "insect", 3.576, 0.315),
    (3,   "insect", 9.060, 1.700),
    (4,   "insect", 4.883, 0.420),
    (5,   "insect", 2.931, 0.437),
    (6,   "insect", 3.342, 0.476),
    (7,   "insect", 1.170, 0.850),
    (8,   "insect", 0.270, 1.250),
    (9,   "insect", 0.774, 0.464),
    (10,  "insect", 15.790, 2.610),
    (11,  "insect", 13.880, 1.920),
    (12,  "insect", 2.320, 1.340),
    ("13.1", "fish", 0.127, 0.995),
    ("13.2", "fish", 0.016, 0.432),
    (14,  "frog",   0.770, 0.135),
    (15,  "frog",   1.120, 0.105),
    (16,  "frog",   2.110, 0.140),
    (17,  "frog",   0.960, 0.080),
    (18,  "frog",   1.110, 0.290),
    (19,  "frog",   0.350, 0.310),
    (20,  "bird",   0.150, 1.020),
    (21,  "bird",   0.620, 0.550),
    (22,  "bird",   9.300, 3.560),
    (23,  "bird",   0.640, 0.610),
    (24,  "bird",   0.222, 0.162),
], columns=["sp_no", "group", "signal", "rest"])

# Photeros summary values
small_day = 1.181223
small_night = 2.097811
cylinder_night_mean = 5.844194
medium_night = 3.614779  # swimming/activity baseline

# Cylinder trial/channel data
cyl = pd.DataFrame({
    "trial": [1, 1, 1, 3, 3, 3, 4, 4, 5, 5],
    "channel": ["Ch2", "Ch3", "Ch4", "Ch2", "Ch3", "Ch4", "Ch2", "Ch4", "Ch2", "Ch4"],
    "M_obs": [8.546660, 8.352764, 7.555755, 5.227565, 3.558230, 7.572332, 0.158096, -0.103040, 3.042832, 2.897411],
    "signal_rate": [9.745342, 0.981366, 4.161491, 0.174402, 0.485232, 0.233474, 0.087622, 0.051460, 0.391549, 0.108451],
})

# Behavioral conversion values
pulses_per_train = 4.5
train_duration_s = 16.017

# =========================================================
# 2) DERIVED VALUES
# =========================================================

lit["ln_rest"] = np.log(lit["rest"])
lit["ln_signal"] = np.log(lit["signal"])

# Trial-specific duty cycle
cyl["trains_per_hr"] = cyl["signal_rate"] / pulses_per_train
cyl["signal_time_s_per_hr"] = cyl["trains_per_hr"] * train_duration_s
cyl["f"] = cyl["signal_time_s_per_hr"] / 3600.0

# Assumption:
# During non-signaling time, animals are at medium-night swimming/activity rate.
# M_obs = f * M_sig + (1 - f) * M_swim
# => M_sig = [M_obs - (1-f) * M_swim] / f
cyl["M_sig"] = (cyl["M_obs"] - (1.0 - cyl["f"]) * medium_night) / cyl["f"]

# Valid under this assumption only if M_sig > 0 and finite
cyl["valid"] = np.isfinite(cyl["M_sig"]) & (cyl["M_sig"] > 0)
cyl["ln_M_sig"] = np.where(cyl["valid"], np.log(cyl["M_sig"]), np.nan)

print(cyl[["trial", "channel", "M_obs", "signal_rate", "f", "M_sig", "valid"]])

# =========================================================
# 3) OPTIONAL: PHYLOPIC ICONS
# =========================================================
# PhyloPic has official API docs and usage/licensing guidance. :contentReference[oaicite:1]{index=1}
#
# Easiest workflow:
#   - manually pick 1 silhouette per major group on phylopic.org
#   - download PNG/SVG into a local folder
#   - point this dict at those files
#
# Example expected filenames:
#   icons/spider.png
#   icons/insect.png
#   icons/fish.png
#   icons/frog.png
#   icons/bird.png

ICON_DIR = Path("icons")
icon_paths = {
    "spider": ICON_DIR / "spider.png",
    "insect": ICON_DIR / "insect.png",
    "fish":   ICON_DIR / "fish.png",
    "frog":   ICON_DIR / "frog.png",
    "bird":   ICON_DIR / "bird.png",
}

def add_icon(ax, x, y, path, zoom=0.12):
    """Add a raster icon if file exists; otherwise silently skip."""
    path = Path(path)
    if not path.exists():
        return
    img = plt.imread(path)
    artist = AnnotationBbox(
        OffsetImage(img, zoom=zoom),
        (x, y),
        frameon=False,
        box_alignment=(0.5, 0.5),
        zorder=3,
    )
    ax.add_artist(artist)

# =========================================================
# 4) PLOTTING
# =========================================================

fig, ax = plt.subplots(figsize=(9, 8))

# Axes limits
xmin, xmax = -3, 2
ymin, ymax = -5, 3.6
ax.set_xlim(xmin, xmax)
ax.set_ylim(ymin, ymax)

# Reference contours (parallel to unity slope)
xline = np.linspace(xmin, xmax, 300)
for intercept in range(-2, 4):
    ax.plot(xline, xline + intercept, lw=0.8, alpha=0.14, color="0.6", zorder=0)

# Unity line
ax.plot(xline, xline, lw=1.1, color="0.35", zorder=1)

# Literature points
# If icons are present, use them; otherwise use plain points.
for _, row in lit.iterrows():
    if icon_paths[row["group"]].exists():
        add_icon(ax, row["ln_rest"], row["ln_signal"], icon_paths[row["group"]], zoom=0.11)
    else:
        ax.scatter(row["ln_rest"], row["ln_signal"], s=48, alpha=0.7, color="tab:blue", zorder=2)

    ax.annotate(
        str(row["sp_no"]),
        (row["ln_rest"], row["ln_signal"]),
        xytext=(7, 5),
        textcoords="offset points",
        fontsize=9,
        zorder=4,
    )

# Observed Photeros points
x_day = np.log(small_day)
x_night = np.log(small_night)
y_obs = np.log(cylinder_night_mean)

ax.scatter([x_day], [y_obs], marker="*", s=280, color="#f57c00", zorder=6)
ax.scatter([x_night], [y_obs], marker="*", s=280, color="#2ca02c", zorder=6)

ax.annotate(
    "Photeros\n(day rest)",
    (x_day, y_obs),
    xytext=(-22, -28),
    textcoords="offset points",
    fontsize=9,
    ha="right",
    zorder=7,
)

ax.annotate(
    "Photeros\n(night rest)",
    (x_night, y_obs),
    xytext=(12, -28),
    textcoords="offset points",
    fontsize=9,
    ha="left",
    zorder=7,
)

# Corrected feasible region:
# valid trial-specific corrected ln(M_sig), shown at both x positions
valid_y = cyl.loc[cyl["valid"], "ln_M_sig"].dropna().values

# Only keep values within plotted range for display,
# but preserve true max for possible annotation.
valid_y_in_plot = valid_y[(valid_y >= ymin) & (valid_y <= ymax)]

# Faint points at both x values
for yv in valid_y_in_plot:
    ax.scatter([x_day], [yv], s=36, color="#f57c00", alpha=0.22, zorder=5)
    ax.scatter([x_night], [yv], s=36, color="#2ca02c", alpha=0.22, zorder=5)

# Vertical band connecting the two x choices over the visible region
if len(valid_y_in_plot) > 0:
    y0 = float(np.min(valid_y_in_plot))
    y1 = float(np.max(valid_y_in_plot))

    band = Rectangle(
        (min(x_day, x_night), y0),
        abs(x_night - x_day),
        y1 - y0,
        facecolor="0.2",
        edgecolor="none",
        alpha=0.06,
        zorder=2,
    )
    ax.add_patch(band)

    # Draw faint boundary lines
    ax.plot([x_day, x_day], [y0, y1], ls="--", lw=1.0, color="#f57c00", alpha=0.45, zorder=4)
    ax.plot([x_night, x_night], [y0, y1], ls="--", lw=1.0, color="#2ca02c", alpha=0.45, zorder=4)

    # Place label inside or just above visible region, not floating in whitespace
    label_y = min(y1 + 0.08, ymax - 0.18)
    ax.text(
        (x_day + x_night) / 2,
        label_y,
        "Duty-cycle corrected\nfeasible range",
        ha="center",
        va="bottom",
        fontsize=10,
        zorder=7,
        bbox=dict(boxstyle="round,pad=0.2", fc="white", ec="none", alpha=0.75),
    )

# Optional: indicate that many corrected values lie off-scale
n_offscale_high = int(np.sum(valid_y > ymax))
if n_offscale_high > 0:
    ax.annotate(
        f"{n_offscale_high} corrected values\nabove plotting range",
        xy=((x_day + x_night) / 2, ymax - 0.02),
        xytext=(0, -6),
        textcoords="offset points",
        ha="center",
        va="top",
        fontsize=9,
        zorder=7,
    )

# Axis labels
ax.set_xlabel("ln resting metabolic rate")
ax.set_ylabel("ln signaling metabolic rate")

# Remove title if you want journal-style figure
# ax.set_title("Comparative signaling costs with Photeros")

plt.tight_layout()
plt.show()
